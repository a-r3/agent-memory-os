# Agent Memory OS local development environment
#
# Copy this file to `.env` and adjust values for your local machine. Do not
# place real secrets in version control.

# General
APP_ENV=development
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1
PYTHONPATH=/workspace

# Canonical storage paths
AMOS_STORAGE_ROOT=/workspace/storage
AMOS_STORAGE_DOCS=/workspace/storage/docs
AMOS_STORAGE_SNAPSHOTS=/workspace/storage/snapshots
AMOS_STORAGE_EXPORTS=/workspace/storage/exports
AMOS_STORAGE_ARCHIVES=/workspace/storage/archives

# Gateway / MCP
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
MCP_HOST=0.0.0.0
MCP_PORT=9090
MCP_SERVER_MODULE=mcp.tools

# Compiler defaults
DEFAULT_AGENT=codex
DEFAULT_CONTEXT_BUDGET_TOKENS=1200
DEFAULT_OUTPUT_BUDGET_TOKENS=420
DEFAULT_MEMORY_SCOPE=rule,identity,procedure
DEFAULT_REPO_SCOPE=

# Adapter defaults
CODEX_ADAPTER_ENABLED=true
CLAUDE_ADAPTER_ENABLED=true
GENERIC_ADAPTER_ENABLED=true
CODEX_BUDGET_TOKENS=1200
CLAUDE_BUDGET_TOKENS=1200
GENERIC_BUDGET_TOKENS=1200

# Runtime payload / caching
RUNTIME_PAYLOAD_PREVIEW_ENABLED=true
CACHE_REFRESH_ENABLED=true
REDIS_HOST=memory-cache
REDIS_PORT=6379

# Trust / governance
TRUST_WRITE_BLOCKING_ENABLED=true
SECRET_SCAN_ENABLED=true
POLICY_GATE_ENABLED=true

# Snapshot / export / archive settings
SNAPSHOT_EXPORT_ENABLED=true
SNAPSHOT_IMPORT_ENABLED=true
ARCHIVE_PLAN_ENABLED=true
RECOVERY_WORKER_ENABLED=true

# Placeholder provider credentials
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Placeholder database / vector layer settings for future phases
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=agent_memory_os
POSTGRES_USER=agent_memory_os
POSTGRES_PASSWORD=change-me
VECTOR_INDEX_URL=
